# 데이터베이스 연결 (로컬 개발)
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/iroun_db

# GCP Cloud SQL 연결 (운영 환경 - Cloud Run에서 자동 설정)
# DATABASE_URL=postgresql://USER:PASSWORD@/DB_NAME?host=/cloudsql/PROJECT_ID:REGION:INSTANCE_NAME

# 어드민 패널 비밀번호 (반드시 변경하세요)
ADMIN_PASSWORD=iroun2025!

# 세션 보안 키 (무작위 긴 문자열로 변경하세요)
SESSION_SECRET=change-this-to-a-random-long-string-in-production

# 서버 포트 (Cloud Run은 8080 고정)
PORT=8080

NODE_ENV=development
